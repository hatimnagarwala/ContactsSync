# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/contacts_sync

# JWT
JWT_SECRET=your-jwt-secret-here

# Encryption (AES-256-GCM for tokens/credentials at rest)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/connect/google/callback

# Microsoft OAuth 2.0
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/connect/outlook/callback
MICROSOFT_TENANT_ID=common

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
